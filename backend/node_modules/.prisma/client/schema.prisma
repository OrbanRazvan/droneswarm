generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model GameUser {
  id                Int      @id @default(autoincrement())
  firstName         String
  lastName          String
  username          String?  @unique
  email             String   @unique
  password          String
  isVerified        Boolean  @default(false)
  activationCode    String?
  selectedDrone     String   @default("basic")
  selectedCtfPackId String   @default("ctf-pack-starter-command")
  avatar            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Player {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  mass      Int      @default(1250)
  drones    Int      @default(0)
  skin      String   @default("cyan")
  coins     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("Player")
}

model Skin {
  id        Int     @id @default(autoincrement())
  name      String  @unique
  color     String
  price     Int     @default(0)
  isPremium Boolean @default(false)

  @@map("Skin")
}

// Istoric Battle Royale PvE per meci.
model MatchResult {
  id              Int      @id @default(autoincrement())
  userId          Int?
  username        String
  gameMode        String   @default("battle-royale")
  kills           Int      @default(0)
  totalCollected  Int      @default(0)
  placement       Int
  totalPlayers    Int      @default(60)
  durationSeconds Int      @default(0)
  skin            String   @default("cyan")
  createdAt       DateTime @default(now())

  @@index([userId])
  @@map("MatchResult")
}

// Statistici persistente pentru Dashboard / Global Top 10.
//
// - cont Google: userId este completat, isGuest = false
// - Guest: NU se creeaza GameUser sau Player; se salveaza doar guestKey,
//   username si recordul necesar pentru leaderboard.
//
// bestKills = recordul maxim de kill-uri intr-un singur meci.
// wins = numarul total de meciuri castigate.
model GameModeStat {
  id Int @id @default(autoincrement())

  // Optional pentru ca Guest nu are cont GameUser.
  userId Int?

  // Cheie anonima stabila pe sesiunea Guest; este folosita doar pentru
  // Normal PvP si Battle Royale PvP global Top 10.
  guestKey String?

  // true = record Guest anonim, false = utilizator autentificat.
  isGuest Boolean @default(false)

  username  String
  gameMode  String
  bestKills Int      @default(0)
  wins      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Un singur record per cont si mod.
  @@unique([userId, gameMode])
  // Un singur record Guest anonim per sesiune si mod.
  // PostgreSQL permite multiple valori NULL aici pentru conturile normale.
  @@unique([guestKey, gameMode])
  @@index([gameMode, bestKills])
  @@index([gameMode, wins])
  @@index([gameMode, isGuest])
  @@map("GameModeStat")
}
